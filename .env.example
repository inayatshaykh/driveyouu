# Database
DATABASE_URL=postgresql://username:password@localhost:5432/urs_chauffeur

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# SMS Gateway (MSG91)
MSG91_API_KEY=your-msg91-api-key
MSG91_SENDER_ID=URSCHR

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Payment Gateway (Razorpay - or PayU/Cashfree)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# AWS S3 (for document storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=urs-chauffeur-documents

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# WebSocket Server
WS_PORT=3001
VITE_WS_URL=ws://localhost:3001

# Commission Split
DRIVER_COMMISSION_PERCENTAGE=80
PLATFORM_COMMISSION_PERCENTAGE=20
